# --- Web (local) ---
PORT=3000

# --- PostgreSQL (Railway injects DATABASE_URL on deploy) ---
# Used by: optional Express security API (src/), persistent_store (spectre_kv) when backend is railway.
# Local example:
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/spectre
# Disable SSL for asyncpg (Python) when using local Postgres without TLS:
# PGSSLMODE=disable
# Use system CA verification for remote Postgres instead of the default permissive context:
# ASYNCPG_SSL_STRICT=1
# Node security API mirrors this for local dev (see src/db.js):
# PGSSLMODE=disable

# --- JWT (Express security API only) ---
JWT_SECRET=replace-me-with-a-long-secret
NODE_ENV=development

# --- Persistence backend (Python: config.py / persistent_store) ---
# When unset: if DATABASE_URL is set -> railway (Postgres spectre_kv); else -> spaces (S3 or local).
# PERSISTENCE_BACKEND=spaces
# PERSISTENCE_BACKEND=railway

# --- S3-compatible object storage (storage_spaces: dossiers, JSON, images, etc.) ---
# Omit credentials or set FORCE_LOCAL_STORAGE=1 to use local disk (see SPECTRE_LOCAL_ROOT / SPACES_ROOT).
# For AWS S3 you may omit S3_ENDPOINT_URL (boto3 uses default regional endpoints).
# For DigitalOcean Spaces, Cloudflare R2, MinIO, etc., set endpoint explicitly.
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# S3_BUCKET=
# S3_REGION=us-east-1
# S3_ENDPOINT_URL=
# Optional key prefix inside the bucket:
# S3_ROOT_PREFIX=

# --- Local filesystem storage fallback ---
# FORCE_LOCAL_STORAGE=1
# SPECTRE_LOCAL_ROOT=
# SPACES_ROOT=

# --- Railway / Discord (production) ---
# DISCORD_TOKEN= or DISCORD_BOT_TOKEN=
# RUN_DISCORD_BOT=auto
# RAILWAY_ENVIRONMENT is set by Railway (do not set locally).
